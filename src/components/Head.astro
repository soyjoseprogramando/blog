---
const isProd = import.meta.env.PROD;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedDate?: string;
  updatedDate?: string;
}

const SITE_URL = "https://joseprogramando.com";
const SITE_NAME = "Jose Programando";
const DEFAULT_DESCRIPTION = "Blog sobre Linux y desarrollo web por Jose.";
const DEFAULT_IMAGE = `${SITE_URL}/og-default.jpg`;

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_IMAGE,
  type = "website",
  publishedDate,
  updatedDate,
} = Astro.props;

const fullTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
---

<head>
  <!-- Esenciales -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Primary Meta Tags -->
  <title>{fullTitle}</title>
  <meta name="title" content={fullTitle} />
  <meta name="description" content={description} />

  <!-- Open Graph (Facebook, LinkedIn, WhatsApp) -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:locale" content="es_CO" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonicalURL} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Fuentes -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&display=swap"
    rel="stylesheet"
  />

  <!-- Google Analytics (solo en producción) -->
  {
    isProd && (
      <>
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZVHPS5WXQP" />
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', 'G-ZVHPS5WXQP');
        </script>
      </>
    )
  }

  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Schema: WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Jose Programando",
    "url": "https://joseprogramando.com",
    "description": description,
    "inLanguage": "es",
    "author": {
      "@type": "Person",
      "name": "Jose Ever Muñoz Muñoz",
      "url": "https://joseprogramando.com"
    }
  })} />

  <!-- Schema: BlogPosting (solo en artículos) -->
  {type === "article" && publishedDate && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "image": image,
      "url": canonicalURL,
      "datePublished": publishedDate,
      "dateModified": updatedDate ?? publishedDate,
      "inLanguage": "es",
      "author": {
        "@type": "Person",
        "name": "Jose Ever Muñoz Muñoz",
        "url": "https://joseprogramando.com"
      },
      "publisher": {
        "@type": "Person",
        "name": "Jose Ever Muñoz Muñoz",
        "url": "https://joseprogramando.com"
      }
    })} />
  )}

</head>