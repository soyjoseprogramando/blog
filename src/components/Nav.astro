---
import { Logs, SquareTerminal, Server, X } from "@lucide/astro";

const navItems = [
  { path: "/blog", label: "blog" },
  { path: "/about", label: "about" },
];

const currentPath = Astro.url.pathname;
const isItemActive = (itemPath: string) => {
  if (itemPath === "/blog") {
    return (
      currentPath === "/" ||
      currentPath === "/blog" ||
      currentPath.startsWith("/blog/")
    );
  }

  return currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
};
---

<nav>
  <div class="nav">
    <div class="nav__brand">
      <SquareTerminal color="#ff6b35" />
      <a href="/" class="nav__username">~/joseprogramando</a>
    </div>

    <div class="desktop-menu" aria-label="Desktop navigation">
      {
        navItems.map((item, idx) => (
          <a
            href={item.path}
            class={`desktop-menu__link ${isItemActive(item.path) ? "desktop-menu__link--active" : ""}`}
            aria-current={isItemActive(item.path) ? "page" : undefined}
          >
            <p class="desktop-menu__idx">[ {idx + 1} ]</p>
            <p class="desktop-menu__label">
              <span>/</span>
              {item.label}
            </p>
          </a>
        ))
      }
    </div>

    <button
      id="menu"
      class="nav__menu-btn"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Logs id="logs-icon" />
      <X id="close-menu" color="#ff6b35" stroke-width={3} class="hidden" />
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu">
    <div class="mobile-menu__nav">
      {
        navItems.map((item, idx) => (
          <a
            href={item.path}
            class={`mobile-menu__link ${isItemActive(item.path) ? "mobile-menu__link--active" : ""}`}
            aria-current={isItemActive(item.path) ? "page" : undefined}
          >
            <p class="mobile-menu__idx">[{idx + 1}]</p>
            <p class="mobile-menu__label">
              <span>/</span>
              {item.label}
            </p>
          </a>
        ))
      }
    </div>

    <hr />
    <div class="system">
      <div class="system__title">
        <Server color="#ff6b35" size={16} />
        <p>SYSTEM STATUS</p>
      </div>
      <div class="system__info">
        <p class="system__user">josepro@menu:~$ <span>uptime</span></p>
        <p class="system__uptime">24 days, 6:42</p>
      </div>
      <div class="social-media">
        <p>[github]</p>
        <p>[twitter]</p>
      </div>
    </div>
  </div>
</nav>

<script>
  const $menuIcon = document.getElementById("menu"),
    $mobileMenu = document.getElementById("mobile-menu"),
    $logsIcon = document.getElementById("logs-icon"),
    $closeIcon = document.getElementById("close-menu");

  const desktopMedia = window.matchMedia("(min-width: 768px)");

  const closeMobileMenu = () => {
    $mobileMenu?.classList.remove("show", "hide");
    $logsIcon?.classList.remove("hidden");
    $closeIcon?.classList.add("hidden");
    $menuIcon?.setAttribute("aria-expanded", "false");
    $menuIcon?.setAttribute("aria-label", "Open navigation menu");
  };

  const syncMenuByViewport = () => {
    if (desktopMedia.matches) {
      closeMobileMenu();
    }
  };

  syncMenuByViewport();
  desktopMedia.addEventListener("change", syncMenuByViewport);

  $menuIcon?.addEventListener("click", () => {
    if (desktopMedia.matches) return;

    const isOpen = $mobileMenu?.classList.contains("show");

    if (isOpen) {
      $mobileMenu?.classList.remove("show");
      $mobileMenu?.classList.add("hide");

      $logsIcon?.classList.remove("hidden");
      $closeIcon?.classList.add("hidden");
      $menuIcon?.setAttribute("aria-expanded", "false");
      $menuIcon?.setAttribute("aria-label", "Open navigation menu");

      setTimeout(() => {
        $mobileMenu?.classList.remove("hide");
      }, 300);
    } else {
      $mobileMenu?.classList.remove("hide");
      $mobileMenu?.classList.add("show");

      $logsIcon?.classList.add("hidden");
      $closeIcon?.classList.remove("hidden");
      $menuIcon?.setAttribute("aria-expanded", "true");
      $menuIcon?.setAttribute("aria-label", "Close navigation menu");
    }
  });
</script>

<style>
  nav {
    height: 4rem;
  }
  .nav {
    background-color: var(--background-dark);
    position: fixed;
    top: 0; /* Fijo arriba */
    left: 0; /* Desde el borde izquierdo */
    right: 0; /* Hasta el borde derecho */
    width: 100%; /* Ocupa todo el ancho */
    height: 4rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #333333;
    z-index: 999;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav__username {
    color: inherit;
    text-decoration: none;
    font-weight: bold;
    display: flex;
    align-items: center;
  }

  .nav__username:hover {
    opacity: 0.8;
  }

  .desktop-menu {
    display: none;
  }

  .desktop-menu__link {
    color: inherit;
    text-decoration: none;
    font-weight: bold;
    font-size: 0.9rem;
    padding: 0.35rem 0.65rem;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 12px;
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .desktop-menu__idx {
    color: var(--orange);
    font-size: 0.875rem;
    opacity: 0.5;
  }

  .desktop-menu__link--active .desktop-menu__idx {
    opacity: 1;
  }

  .desktop-menu__label {
    display: flex;
    gap: 1px;
    color: var(--text-grey);
  }

  .desktop-menu__label span {
    color: var(--orange);
  }

  .desktop-menu__link:hover,
  .desktop-menu__link:focus-visible {
    background-color: var(--bg-dark-light);
    outline: none;
  }

  .desktop-menu__link:hover .desktop-menu__label,
  .desktop-menu__link:focus-visible .desktop-menu__label {
    color: var(--text-white);
  }

  .desktop-menu__link--active .desktop-menu__label {
    color: var(--orange);
  }

  .mobile-menu {
    position: fixed;
    top: 4rem;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--background-dark);
    border-bottom: 1px solid #333333;
    z-index: 998;
    display: flex;
    flex-direction: column;
    padding: 1rem;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.3s ease-out,
      transform 0.3s ease-out;
    transform: translateY(-10px);
  }

  .mobile-menu.show {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mobile-menu.hide {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-10px);
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
  }

  .mobile-menu__link {
    color: inherit;
    text-decoration: none;
    padding: 0.5rem;
    font-weight: bold;
    display: flex;
    gap: 12px;
  }

  .mobile-menu__link:hover {
    opacity: 0.8;
  }

  .mobile-menu__link--active .mobile-menu__label {
    color: var(--orange);
  }
  .mobile-menu__link--active .mobile-menu__idx {
    opacity: 1;
  }

  .mobile-menu__link:focus-visible {
    outline: 1px solid var(--orange);
    border-radius: 6px;
    outline-offset: 2px;
  }
  .mobile-menu__idx {
    color: var(--orange);
    font-size: 0.875rem;
    opacity: 0.5;
  }
  .mobile-menu__label {
    display: flex;
    gap: 1px;
  }
  .mobile-menu__label span {
    color: var(--orange);
  }

  .system__title {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .system__title p {
    font-weight: bold;
    font-size: 0.875rem;
  }
  .system__info {
    margin-top: 8px;
    margin-left: 24px;
  }
  .system__user {
    font-size: 0.875rem;
    color: var(--orange);
  }
  .system__user span {
    color: var(--text-white);
  }
  .system__uptime {
    font-size: 0.875rem;
    color: var(--text-grey);
  }
  .social-media {
    margin-top: 16px;
    margin-left: 24px;
    display: flex;
    gap: 16px;
  }
  .social-media p {
    font-size: 0.875rem;
    color: var(--text-grey);
  }
  .hidden {
    display: none;
  }

  .nav__menu-btn {
    border: none;
    background: transparent;
    color: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0.35rem;
    border-radius: 6px;
  }

  .nav__menu-btn:focus-visible {
    outline: 1px solid var(--orange);
    outline-offset: 2px;
  }

  #logs-icon,
  #close-menu {
    transition: opacity 0.3s ease-out;
  }

  @media screen and (min-width: 768px) {
    .desktop-menu {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-left: auto;
    }

    .nav__menu-btn {
      display: none;
    }

    .system {
      display: none;
    }
  }
</style>
